{
  "expo": {
    "name": "MiniShop",
    "slug": "minishop-mobile",
    "scheme": "minishop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06163A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kameltechsolutions.minishop",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
       "permissions": ["CAMERA"],
      "package": "com.kameltechsolutions.minishop",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06163A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "cameraPermission": "L'application a besoin d'accéder à la caméra pour prendre des photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "L'application a besoin d'accéder à la caméra pour prendre des photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}