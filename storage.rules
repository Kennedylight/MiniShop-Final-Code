rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Photos produits : lecture publique (vitrine), écriture par le propriétaire.
    match /products/{ownerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerId;
    }

    // Logos de boutique : lecture publique, écriture par le propriétaire.
    match /owners/{ownerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerId;
    }
  }
}
